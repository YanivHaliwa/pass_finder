#!/usr/bin/env python3

import os
import re
import argparse
import json
from termcolor import colored

def search_keyword_in_file(file_path, keyword, grep_length, search_comments):
    """Search for a keyword within a file and return matching lines."""
    with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()

        # Prepare regex for search
        if search_comments:
            pattern = re.compile(r"(<!--.{0,%d}%s.{0,%d}-->|(#.{0,%d}%s.{0,%d})|//.{0,%d}%s.{0,%d}|\"\"\".{0,%d}%s.{0,%d}\"\"\")" %
                                 (grep_length, keyword, grep_length, grep_length, keyword, grep_length, grep_length, keyword, grep_length, grep_length, keyword, grep_length),
                                 re.IGNORECASE)
        else:
            pattern = re.compile(r".{0,%d}%s.{0,%d}" % (grep_length, keyword, grep_length), re.IGNORECASE)
        
        # Find all matches
        matches = pattern.findall(content)
        return matches

def is_excluded(file_path, exclude_dirs, exclude_files):
    """Check if a file or directory is excluded based on exclusion lists."""
    # Check if the file is in any excluded directories
    for exclude_dir in exclude_dirs:
        if exclude_dir in file_path:
            return True

    # Check if the file is in the excluded files list
    for exclude_file in exclude_files:
        if file_path.endswith(exclude_file):
            return True

    return False


